# ARIA v3 — Environment Configuration
# Copy this file to .env and fill in your API keys

# Groq — free at https://console.groq.com
# 30 RPM free tier, llama-3.3-70b model
GROQ_API_KEY=gsk_your_groq_api_key_here

# NVIDIA NIM — free at https://build.nvidia.com
# 40 RPM free tier, multiple models available
NVIDIA_API_KEY=nvapi_your_nvidia_api_key_here

# GitHub — free at https://github.com/settings/tokens
# Increases API rate limits for code search
GITHUB_TOKEN=ghp_your_github_token_here

# Optional — add when configuring messaging
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_USER_ID=your_user_id
